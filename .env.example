# Bu dosyayi `.env` olarak kopyala ve kendi degerlerini yaz.
#   cp .env.example .env
# .env dosyasi gizli kalmalidir (git'e eklenmez, kimseyle paylasilmaz).

# BotFather'dan aldigin bot token'i:
TELEGRAM_TOKEN=

# Senin chat ID'in (bot ile konusup getUpdates'ten ogrenilir):
TELEGRAM_CHAT_ID=

# --- GEMINI (LLM-analist) ---
# Yol A) Vertex AI (Google Cloud kredisini kullanir; projede FATURALANDIRMA sart):
GEMINI_BACKEND=vertex
GOOGLE_CLOUD_PROJECT=gen-lang-client-0581275112
GOOGLE_CLOUD_LOCATION=us-central1
# Yol B) AI Studio (en basit, ucretsiz kota; faturalandirma GEREKMEZ):
#   GEMINI_BACKEND=aistudio
#   GEMINI_API_KEY=aistudio.google.com/apikey adresinden al
GEMINI_API_KEY=
# Model (opsiyonel): hizli/ucuz gemini-2.5-flash ; derin akil gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash
